# ================================
# maisonDeux - Environment Template
# (with purpose for each variable)
# ================================

# ----------------
# Supabase
# ----------------
# SUPABASE_URL:
#   Base URL of your Supabase project (used for Supabase client calls).
SUPABASE_URL=

# SUPABASE_ANON_KEY:
#   Public key for client-safe Supabase operations.
SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY:
#   Server-only admin key for privileged Supabase operations.
#   Never expose to frontend/mobile.
SUPABASE_SERVICE_ROLE_KEY=

# ----------------
# AI / Vision
# ----------------
# OPENAI_API_KEY:
#   Required for image understanding in search pipeline (vision analysis).
OPENAI_API_KEY=

# SERPAPI_API_KEY:
#   Required for Google Lens reverse-image lookup to infer likely brand/model
#   before marketplace text search.
SERPAPI_API_KEY=

# XIMILAR_API_KEY:
#   Optional fallback computer-vision provider if enabled in future.
XIMILAR_API_KEY=

# GOOGLE_CLOUD_VISION_API_KEY:
#   Optional fallback vision provider if enabled in future.
GOOGLE_CLOUD_VISION_API_KEY=

# ----------------
# eBay
# ----------------
# EBAY_APP_ID:
#   eBay OAuth client ID used to obtain app token.
EBAY_APP_ID=

# EBAY_CERT_ID:
#   eBay OAuth client secret used with APP_ID for token exchange.
EBAY_CERT_ID=

# EBAY_DEV_ID:
#   eBay developer identifier (currently mostly informational/future use).
EBAY_DEV_ID=

# EBAY_OAUTH_TOKEN:
#   Optional pre-generated token. If set, app can use this directly
#   instead of generating one via APP_ID/CERT_ID.
EBAY_OAUTH_TOKEN=

# EBAY_REDIRECT_URI:
#   eBay OAuth redirect/RuName identifier for auth-code flows (if used).
EBAY_REDIRECT_URI=

# EBAY_ENVIRONMENT:
#   eBay environment used by related integrations (production/sandbox).
EBAY_ENVIRONMENT=production

# EBAY_MARKETPLACE_ID:
#   eBay marketplace for Browse API queries (example: EBAY_US, EBAY_GB, EBAY_DE).
EBAY_MARKETPLACE_ID=EBAY_US

# EBAY_ACCOUNT_DELETION_ENDPOINT:
#   Public webhook URL eBay calls for account deletion notifications.
EBAY_ACCOUNT_DELETION_ENDPOINT=

# EBAY_VERIFICATION_TOKEN:
#   Verification token eBay includes for account deletion webhook validation.
EBAY_VERIFICATION_TOKEN=

# ----------------
# ShopGoodwill (unofficial realtime endpoint)
# ----------------
# SHOPGOODWILL_ENABLED:
#   Toggle ShopGoodwill adapter on/off.
SHOPGOODWILL_ENABLED=true

# SHOPGOODWILL_API_ROOT:
#   Base URL for ShopGoodwill search endpoint.
SHOPGOODWILL_API_ROOT=https://buyerapi.shopgoodwill.com/api

# ----------------
# The RealReal
# ----------------
# THEREALREAL_API_KEY:
#   Auth key for The RealReal partner API.
THEREALREAL_API_KEY=

# THEREALREAL_API_SECRET:
#   Secret credential for The RealReal partner API.
THEREALREAL_API_SECRET=

# THEREALREAL_BASE_URL:
#   Base endpoint for The RealReal API (if custom/provided by partner).
THEREALREAL_BASE_URL=

# ----------------
# Chrono24
# ----------------
# CHRONO24_API_KEY:
#   Auth key for Chrono24 partner API.
CHRONO24_API_KEY=

# CHRONO24_API_SECRET:
#   Secret credential for Chrono24 partner API.
CHRONO24_API_SECRET=

# CHRONO24_BASE_URL:
#   Base endpoint for Chrono24 API (if custom/provided by partner).
CHRONO24_BASE_URL=

# ----------------
# Other marketplaces (optional)
# ----------------
# FIRSTDIBS_API_KEY:
#   Credential for 1stDibs integration (if/when live connector is used).
FIRSTDIBS_API_KEY=

# VESTIAIRE_API_KEY:
#   Auth key for Vestiaire API.
VESTIAIRE_API_KEY=

# VESTIAIRE_BASE_URL:
#   Base endpoint for Vestiaire API.
VESTIAIRE_BASE_URL=

# REBAG_API_KEY:
#   Credential for Rebag integration (if/when live connector is used).
REBAG_API_KEY=

# GRAILED_API_KEY:
#   Credential for Grailed integration (if/when live connector is used).
GRAILED_API_KEY=

# FASHIONPHILE_API_KEY:
#   Credential for Fashionphile integration (if/when live connector is used).
FASHIONPHILE_API_KEY=

# WATCHBOX_API_KEY:
#   Credential for WatchBox integration (if/when live connector is used).
WATCHBOX_API_KEY=

# CHRONEXT_API_KEY:
#   Credential for Chronext integration (if/when live connector is used).
CHRONEXT_API_KEY=

# ----------------
# Core Infrastructure
# ----------------
# DATABASE_URL:
#   PostgreSQL connection string for Prisma models (Search, Listing, etc).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luxefinder

# REDIS_URL:
#   Redis connection for BullMQ jobs, rate limiting, and metrics.
REDIS_URL=redis://localhost:6379

# ----------------
# App Runtime
# ----------------
# NODE_ENV:
#   Runtime mode (development/production); affects logging and behavior.
NODE_ENV=development

# PORT:
#   HTTP port Fastify API listens on.
PORT=3000

# JWT_SECRET:
#   Secret for signing/verifying JWTs in API auth.
#   Use a long random value in production.
JWT_SECRET=replace-with-long-random-secret

# PUBLIC_BASE_URL:
#   Public API URL used for temporary image URLs that Google Lens can fetch.
#   For production this should be your public domain (e.g. https://maisondeux.vip).
PUBLIC_BASE_URL=http://localhost:3000

# ----------------
# Mobile
# ----------------
# EXPO_PUBLIC_API_BASE_URL:
#   Base URL mobile app uses to call maisonDeux API.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
